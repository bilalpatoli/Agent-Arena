# Copy to .env.local and fill in.
# No key → the arena runs on the deterministic mock runner (demo-safe).
# Key set → the HybridRunner uses live Gemini 3.5 computer-use, falling back to
# mock on any error.
GEMINI_API_KEY=

# Where the live computer-use browser points for the /challenge page.
ARENA_BASE_URL=http://localhost:3001

# Set to 0 to force mock even when a key is present (use on stage to keep the
# demo fast + deterministic; unset/1 = attempt live runs).
ARENA_LIVE=1

# Which challenge the arena runs:
#   saucedemo → real saucedemo.com checkout, replays captured Gemini trajectories (default, headline)
#   signup    → synthetic local trap page, mock/live hybrid (fallback)
# saucedemo trajectories are committed under data/trajectories/ — works on a fresh clone.
ARENA_CHALLENGE=saucedemo

# Live "paste a URL" mode (/live) only. Set to 1 to disable BENIGN Gemini
# computer-use safety gates (cookie consent, account creation, form/data) so
# agents can navigate real commercial sites without stalling. "financial_
# transactions" is NEVER disabled — agents can't complete a real purchase.
# OFF by default. Only enable for sandboxed demos on sites you control/trust.
ARENA_RELAX_SAFETY=0
